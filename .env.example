# career-ops-web environment

# OpenAI-compatible Claude proxy. Reuse the same values you have in
# /opt/job-searcher/.env on the droplet (oauth2api endpoint).
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=auto

# Where this app's user-state (reports, tracker, story bank) is written.
# Default ./data which is gitignored.
DATA_DIR=./data

# Path to the cloned career-ops repo on disk. The setup.sh script clones
# santifer/career-ops to /opt/career-ops on the droplet by default; for
# local dev clone it adjacent and point to ../career-ops.
CAREER_OPS_DIR=../career-ops

# HTTP port. nginx vhost proxies https://careerops.hemnaath.tech to this.
PORT=8001

# =============================================================================
# Premium-API search (/search page). All optional — providers without keys
# simply skip themselves at request time.
# =============================================================================

# Apify (LinkedIn + Google Jobs scrapers). Get a token at apify.com →
# Settings → Integrations → Personal API tokens. Free tier $5/mo credit.
APIFY_TOKEN=
# Override actor IDs if defaults break (tilde or slash both accepted):
# APIFY_LINKEDIN_ACTOR=bebity~linkedin-jobs-scraper
# APIFY_GOOGLE_ACTOR=dan.foreman~google-jobs-scraper
# APIFY_PER_QUERY_LIMIT=25

# TheirStack. Sign up at theirstack.com → Dashboard → API Keys. Free tier
# 200 credits/month, 1 credit per job returned.
THEIRSTACK_API_KEY=
THEIRSTACK_COUNTRIES=US

# bluedoor — anonymous works (~50 req/short window); OTP signup at
# https://api.bluedoor.sh/job-postings/v1/auth/otp for higher limits.
BLUEDOOR_API_KEY=
